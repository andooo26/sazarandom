{
  "manifest_version": 3,
  "name": "さざらんだむ",
  "version": "1.0",
  "description": "弊サークルで順番をランダムで決める拡張機能",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Saza Random",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://drive.google.com/*",
    "https://drive.usercontent.google.com/*"
  ]
}
